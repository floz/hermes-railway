# ──────────────────────────────────────────────────────────────────────────
# REQUIRED — set in Railway dashboard (Settings → Variables, mark as sealed)
# ──────────────────────────────────────────────────────────────────────────

# Strong random password (32+ chars). Generate with:
#   openssl rand -base64 32
ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────────────────────────────────────────

# Override the basic_auth username (default: admin)
# ADMIN_USERNAME=admin

# Override the Hermes Agent version. Default is pinned in the Dockerfile
# (currently v2026.4.30). Set this to bump without editing code — Railway
# will rebuild and redeploy automatically.
# Use `latest` for bleeding edge (not recommended for production: a breaking
# upstream change can break your deploy at the next rebuild).
# Available tags: https://hub.docker.com/r/nousresearch/hermes-agent/tags
# HERMES_VERSION=v2026.4.30

# PORT is set automatically by Railway. Do NOT override.

# ──────────────────────────────────────────────────────────────────────────
# Hermes provider/channel keys — optional. You can also configure them
# via the dashboard after first deploy. Hermes reads /opt/data/.env at
# gateway start; Railway exports all service variables into the container,
# so anything you set here ends up available to Hermes.
# ──────────────────────────────────────────────────────────────────────────

# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# Discord
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# OpenCode Zen — OpenAI-compatible custom provider. Configure as a custom
# provider via the Hermes dashboard after deploy:
#   base_url: https://opencode.ai/zen/v1
#   model id format: opencode/<model>  (e.g. opencode/gpt-5.5)
# OPENCODE_ZEN_API_KEY=
